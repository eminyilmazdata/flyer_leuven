# Neon (or any Postgres) connection string — pooled recommended on Vercel
DATABASE_URL=

# Random secret, 32+ chars — volunteer sessions + coordinator cookie signing
SESSION_SECRET=

# Plaintext password coordinators enter at /coordinator/login
COORDINATOR_PASSWORD=

# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Optional: hours before an unfinished reservation is auto-released (default 48, max 168)
# STALE_RESERVATION_HOURS=48
